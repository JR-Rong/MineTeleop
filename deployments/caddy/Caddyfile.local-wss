{
	admin off
}

https://localhost {
	tls internal
	handle_path /api/* {
		reverse_proxy host.docker.internal:18765
	}
	@signaling_api path /health /time /auth/* /drivers/* /vehicles/* /sessions /sessions/* /signaling/*
	handle @signaling_api {
		reverse_proxy host.docker.internal:18765
	}
	handle {
		respond "not found" 404
	}
}
