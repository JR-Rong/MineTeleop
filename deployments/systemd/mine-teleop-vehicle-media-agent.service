[Unit]
Description=Mine Teleop vehicle media agent
After=network-online.target mine-teleop-vehicle-agent.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/mine-teleop
EnvironmentFile=/etc/mine-teleop/mine-teleop.env
LogsDirectory=mine-teleop
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
StateDirectory=mine-teleop/recordings
Environment=GST_PLUGIN_SYSTEM_PATH_1_0=
Environment=GST_PLUGIN_PATH_1_0=/opt/mine-teleop/lib/gstreamer-1.0
Environment=GST_PLUGIN_SCANNER=/opt/mine-teleop/bin/gst-plugin-scanner
Environment=GST_REGISTRY=/var/lib/mine-teleop/recordings/.gstreamer-registry.bin
Environment=LIBVA_DRIVERS_PATH=/opt/mine-teleop/lib/dri
Environment=LD_LIBRARY_PATH=/opt/mine-teleop/lib:/opt/mine-teleop/lib/vendor/chassis:/opt/mine-teleop/lib/vendor/mvs:/opt/mine-teleop/lib/vendor/pylon
ExecStart=/opt/mine-teleop/lib/ld-linux-x86-64.so.2 --library-path /opt/mine-teleop/lib:/opt/mine-teleop/lib/vendor/chassis:/opt/mine-teleop/lib/vendor/mvs:/opt/mine-teleop/lib/vendor/pylon /opt/mine-teleop/bin/mine-teleop vehicle-media-agent --config /etc/mine-teleop/vehicle-agent.yaml --signaling-http-url ${MINE_TELEOP_SIGNALING_HTTP_URL} --device-token ${MINE_TELEOP_DEVICE_TOKEN} --record --recording-root /var/lib/mine-teleop/recordings --service
Restart=on-failure
RestartSec=2
StandardOutput=append:/var/log/mine-teleop/vehicle-media-agent.log
StandardError=append:/var/log/mine-teleop/vehicle-media-agent.log

[Install]
WantedBy=multi-user.target
