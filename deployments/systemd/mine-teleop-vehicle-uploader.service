[Unit]
Description=Mine Teleop vehicle uploader
After=network-online.target mine-teleop-vehicle-agent.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/mine-teleop
EnvironmentFile=/etc/mine-teleop/mine-teleop.env
LogsDirectory=mine-teleop
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictSUIDSGID=yes
StateDirectory=mine-teleop/uploader
Nice=10
IOSchedulingClass=idle
CPUWeight=50
IOWeight=50
ExecStart=/opt/mine-teleop/mine-teleop vehicle-uploader --service --config /etc/mine-teleop/vehicle-agent.yaml --recording-root /var/lib/mine-teleop/recordings --archive-root /var/lib/mine-teleop/uploader/archive
Restart=on-failure
RestartSec=5
StandardOutput=append:/var/log/mine-teleop/vehicle-uploader.log
StandardError=append:/var/log/mine-teleop/vehicle-uploader.log

[Install]
WantedBy=multi-user.target
